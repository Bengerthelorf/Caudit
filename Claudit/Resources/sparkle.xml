        <item>
                    <title>Version 0.0.4</title>
                    <link>https://github.com/Bengerthelorf/Claudit</link>
                    <sparkle:version>2026031701</sparkle:version>
                    <sparkle:shortVersionString>0.0.4</sparkle:shortVersionString>
